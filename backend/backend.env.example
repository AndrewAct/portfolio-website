# Copy this file to backend.env on the server and replace every placeholder.
# Keep backend.env out of Git and Docker images: chmod 600 backend.env

MONGODB_USERNAME=replace-me
MONGODB_PASSWORD=replace-me
MONGODB_CLUSTER=replace-me.mongodb.net
MONGODB_DATABASE=portfolio
IS_DEVELOPMENT=false

GRAFANA_API_KEY=replace-me
GRAFANA_INSTANCE_ID=replace-me
GRAFANA_OTLP_ENDPOINT=https://replace-me.grafana.net/otlp
ENVIRONMENT=production

GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=15
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
