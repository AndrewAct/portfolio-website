# Copy this file to backend.env on the server and replace every placeholder.
# Keep backend.env out of Git and Docker images: chmod 600 backend.env

MONGODB_USERNAME=replace-me
MONGODB_PASSWORD=replace-me
MONGODB_CLUSTER=replace-me.mongodb.net
MONGODB_DATABASE=portfolio
IS_DEVELOPMENT=false

GRAFANA_API_KEY=replace-me
GRAFANA_INSTANCE_ID=replace-me
GRAFANA_OTLP_ENDPOINT=https://replace-me.grafana.net/otlp
ENVIRONMENT=production

GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=15
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Neon Postgres — horoscope email subscriptions. Use the DIRECT (non "-pooler") host: this
# process runs its own asyncpg pool, and Neon's pooled/PgBouncer endpoint doesn't support
# session-level advisory locks that the migration runner relies on.
DATABASE_URL=postgresql://replace-me:replace-me@replace-me.neon.tech/horoscope?sslmode=require

# Resend — outbound email. Disable open/click tracking for this sending domain in the
# Resend dashboard; it is not a per-request API option.
RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL=horoscope@andrewcee.io
# Optional: from_email isn't a real inbox, this gives subscribers a real address to
# reach via "Reply". Leave blank to omit the Reply-To header entirely.
RESEND_REPLY_TO_EMAIL=
RESEND_WEBHOOK_SECRET=replace-me

# HMAC secret signing confirm/preferences/unsubscribe links. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SUBSCRIPTION_TOKEN_SECRET=replace-me
PUBLIC_BASE_URL=https://andrewcee.io
